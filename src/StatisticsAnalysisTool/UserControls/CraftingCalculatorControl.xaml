<UserControl x:Class="StatisticsAnalysisTool.UserControls.CraftingCalculatorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             xmlns:viewModels="clr-namespace:StatisticsAnalysisTool.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="900"
             d:DataContext="{d:DesignInstance Type=viewModels:MainWindowViewModel}">

    <Grid Style="{StaticResource TabItemGridStyle}">
        <StackPanel Orientation="Vertical">
            <!-- Başlık ve açıklama -->
            <StackPanel Orientation="Horizontal" Margin="10,8,10,2">
                <fa5:ImageAwesome Icon="Solid_Hammer" Foreground="{StaticResource SolidColorBrush.Accent.Blue.4}"
                                  Height="16" Width="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding Translation.CraftingCalculator, FallbackValue='CRAFTING CALCULATOR'}"
                           FontSize="16" FontWeight="Light"
                           Foreground="{StaticResource SolidColorBrush.Text.1}" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="{Binding Translation.CraftingCalculatorDescription, FallbackValue='Bir eşya seçmek için çift tıklayın ve crafting hesaplayıcıyı açın.'}"
                       FontSize="12" Foreground="{StaticResource SolidColorBrush.Text.5}" Margin="10,0,10,5" />

            <!-- Arama kutusu -->
            <Grid Margin="0,0,0,0">
                <TextBox x:Name="TxtCraftingSearch"
                         Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsTxtSearchEnabled, FallbackValue=false}"
                         Style="{StaticResource ItemSearchTextBoxStyle}" />
                <Grid Margin="235,11,0,0" Height="20" Width="20" VerticalAlignment="Top" HorizontalAlignment="Left"
                      IsEnabled="{Binding IsFilterResetEnabled, FallbackValue=false}">
                    <fa5:ImageAwesome Icon="Solid_Redo" Foreground="{StaticResource SolidColorBrush.Text.1}" MouseUp="FilterReset_MouseUp" />
                </Grid>
            </Grid>

            <!-- Filtre dropdown'ları -->
            <StackPanel Orientation="Horizontal">
                <ComboBox ItemsSource="{Binding ItemShopCategories}" SelectedItem="{Binding SelectedItemShopCategory, Mode=TwoWay}"
                          SelectedValuePath="Id" DisplayMemberPath="DisplayName" HorizontalAlignment="Left" Margin="10,5,5,5" VerticalAlignment="Top" Width="150" />
                <ComboBox ItemsSource="{Binding ItemSubCategories1}" SelectedItem="{Binding SelectedItemShopSubCategory1, Mode=TwoWay}"
                          SelectedValuePath="Id" DisplayMemberPath="DisplayName" HorizontalAlignment="Left" Margin="5,5" VerticalAlignment="Top" Width="150" />
                <ComboBox ItemsSource="{Binding ItemTiers}" SelectedValue="{Binding SelectedItemTier}"
                          SelectedValuePath="Key" DisplayMemberPath="Value" HorizontalAlignment="Left" Margin="5,5" MinWidth="70" />
                <ComboBox ItemsSource="{Binding ItemLevels}" SelectedValue="{Binding SelectedItemLevel}"
                          SelectedValuePath="Key" DisplayMemberPath="Value" HorizontalAlignment="Left" Margin="5,5" MinWidth="70" />
            </StackPanel>
        </StackPanel>

        <!-- Eşya listesi - çift tıklama ile crafting penceresini açar -->
        <ListView SnapsToDevicePixels="True" ItemsSource="{Binding ItemsView}"
                  ItemContainerStyle="{StaticResource {x:Type ListViewItem}}"
                  Margin="0,110,0,0" SelectionMode="Single"
                  MouseDoubleClick="LvItems_MouseDoubleClick"
                  d:ItemsSource="{d:SampleData ItemCount=5}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="{Binding Translation.Icon, FallbackValue=ICON}" Width="80" CellTemplate="{StaticResource ItemSearch.GridViewColumnIconTemplate}"/>
                    <GridViewColumn Header="{Binding Translation.Name, FallbackValue=NAME}" Width="500" CellTemplate="{StaticResource ItemSearch.GridViewColumnNameTemplate}" />
                    <GridViewColumn Header="{Binding Translation.Favorite, FallbackValue=FAVORITE}" Width="80" CellTemplate="{StaticResource ItemSearch.GridViewColumnFavoriteTemplate}" />
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>

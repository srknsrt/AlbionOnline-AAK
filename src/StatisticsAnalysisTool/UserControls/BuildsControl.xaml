<UserControl x:Class="StatisticsAnalysisTool.UserControls.BuildsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200"
             Loaded="UserControl_Loaded">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Başlık ve Butonlar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Builds" FontSize="18" FontWeight="Bold" Foreground="White"
                       VerticalAlignment="Center" Margin="0,0,20,0"/>
            <Button x:Name="YeniBuildBtn" Content="+ Yeni Build" Click="YeniBuild_Click"
                    Padding="12,6" Background="#2d7a2d" Foreground="White" BorderThickness="0"
                    Margin="0,0,10,0"/>
            <Button Content="Yenile" Click="Yenile_Click"
                    Padding="12,6" Background="#444" Foreground="White" BorderThickness="0"
                    Margin="0,0,20,0"/>
            <TextBlock Text="Kategori:" Foreground="#aaa" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox x:Name="KategoriCombo" Width="140" SelectionChanged="Kategori_Changed"
                      Background="#333" Foreground="White" BorderBrush="#555">
                <ComboBoxItem Content="Tümü" IsSelected="True"/>
                <ComboBoxItem Content="PvP"/>
                <ComboBoxItem Content="PvE"/>
                <ComboBoxItem Content="Ganking"/>
                <ComboBoxItem Content="Gathering"/>
                <ComboBoxItem Content="ZvZ"/>
                <ComboBoxItem Content="HCE"/>
                <ComboBoxItem Content="Arena"/>
                <ComboBoxItem Content="Diğer"/>
            </ComboBox>
        </StackPanel>

        <TextBlock x:Name="DurumText" Grid.Row="1" Foreground="#888" FontSize="12" Margin="0,0,0,8"/>

        <!-- Build Listesi -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="BuildListesi">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#1a1a2e" BorderBrush="#333" BorderThickness="1"
                                CornerRadius="6" Margin="0,0,0,10" Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Build Resmi -->
                                <Border Grid.Column="0" CornerRadius="4" Margin="0,0,12,0"
                                        Background="#111" Width="200" Height="150" Cursor="Hand">
                                    <Image Source="{Binding BuildImage}" Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           MouseLeftButtonDown="BuildImage_Click" Tag="{Binding}"/>
                                </Border>

                                <!-- Bilgiler -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="Bold"
                                                   Foreground="White" Margin="0,0,10,0"/>
                                        <Border Background="#2d5a7a" CornerRadius="3" Padding="6,2">
                                            <TextBlock Text="{Binding Category}" Foreground="White" FontSize="11"/>
                                        </Border>
                                    </StackPanel>

                                    <TextBlock Text="{Binding Description}" Foreground="#aaa" FontSize="12"
                                               TextWrapping="Wrap" Margin="0,0,0,8"
                                               MaxWidth="500" TextTrimming="CharacterEllipsis"
                                               MaxHeight="40"/>

                                    <TextBlock Foreground="#666" FontSize="11" Margin="0,4,0,0">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} · {1}">
                                                <Binding Path="CreatedBy"/>
                                                <Binding Path="CreatedAtFormatted"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Like -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <Button Content="+" Tag="{Binding}" Click="Like_Click"
                                            FontSize="18" Padding="8,4"
                                            Background="Transparent" Foreground="White" BorderThickness="0"
                                            Cursor="Hand"/>
                                    <TextBlock Text="{Binding Likes}" Foreground="#aaa" FontSize="13"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Büyük Resim Önizleme -->
        <Grid x:Name="BuyukResimPanel" Grid.Row="0" Grid.RowSpan="3"
              Background="#CC000000" Visibility="Collapsed"
              MouseLeftButtonDown="BuyukResimKapat_Click" Cursor="Hand">
            <Border Background="#1a1a2e" BorderBrush="#555" BorderThickness="2"
                    CornerRadius="8" Padding="12"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    MaxWidth="900" MaxHeight="700">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock x:Name="BuyukResimBaslik" FontSize="16" FontWeight="Bold"
                                   Foreground="White" Margin="0,0,10,0"/>
                        <Border x:Name="BuyukResimKategori" Background="#2d5a7a" CornerRadius="3" Padding="6,2"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="BuyukResimKategoriText" Foreground="White" FontSize="11"/>
                        </Border>
                    </StackPanel>
                    <Image x:Name="BuyukResimImage" Stretch="Uniform" MaxHeight="600"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="Kapatmak için tıklayın" Foreground="#666" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Yeni Build Formu -->
        <Border x:Name="BuildFormu" Grid.Row="0" Grid.RowSpan="3"
                Background="#0d0d1a" BorderBrush="#555" BorderThickness="2"
                CornerRadius="8" Padding="20" Visibility="Collapsed"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                MinWidth="500" MaxWidth="700">
            <StackPanel>
                <TextBlock Text="Yeni Build Oluştur" FontSize="16" FontWeight="Bold"
                           Foreground="White" Margin="0,0,0,12"/>

                <TextBlock Text="Build Adı" Foreground="#aaa" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtBuildAdi" Height="28" Background="#1a1a2e"
                         Foreground="White" BorderBrush="#555" Padding="6,4" Margin="0,0,0,8"/>

                <TextBlock Text="Açıklama" Foreground="#aaa" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtAciklama" Height="50" Background="#1a1a2e"
                         Foreground="White" BorderBrush="#555" Padding="6,4"
                         TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,8"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Text="Kategori" Foreground="#aaa" Margin="0,0,0,4"/>
                        <ComboBox x:Name="FormKategori" Width="140" Background="#333"
                                  Foreground="White" BorderBrush="#555">
                            <ComboBoxItem Content="PvP" IsSelected="True"/>
                            <ComboBoxItem Content="PvE"/>
                            <ComboBoxItem Content="Ganking"/>
                            <ComboBoxItem Content="Gathering"/>
                            <ComboBoxItem Content="ZvZ"/>
                            <ComboBoxItem Content="HCE"/>
                            <ComboBoxItem Content="Arena"/>
                            <ComboBoxItem Content="Diğer"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Oluşturan" Foreground="#aaa" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtOlusturan" Width="200" Height="28" Background="#1a1a2e"
                                 Foreground="White" BorderBrush="#555" Padding="6,4"/>
                    </StackPanel>
                </StackPanel>

                <!-- Resim Seçme -->
                <TextBlock Text="Build Resmi" Foreground="#aaa" Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button x:Name="ResimSecBtn" Content="Resim Seç" Click="ResimSec_Click"
                            Padding="12,6" Background="#2d5a7a" Foreground="White" BorderThickness="0"
                            Margin="0,0,10,0"/>
                    <TextBlock x:Name="ResimDurum" Foreground="#666" VerticalAlignment="Center"
                               Text="Henüz resim seçilmedi"/>
                </StackPanel>

                <!-- Resim Önizleme -->
                <Border x:Name="ResimOnizlemeBorder" Background="#111" CornerRadius="4"
                        MaxHeight="250" Margin="0,0,0,12" Visibility="Collapsed">
                    <Image x:Name="ResimOnizleme" Stretch="Uniform" MaxHeight="240"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>

                <!-- Butonlar -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="İptal" Click="FormIptal_Click"
                            Padding="16,6" Background="#7a2d2d" Foreground="White"
                            BorderThickness="0" Margin="0,0,8,0"/>
                    <Button Content="Kaydet ve Paylaş" Click="FormKaydet_Click"
                            Padding="16,6" Background="#2d7a2d" Foreground="White"
                            BorderThickness="0"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="StatisticsAnalysisTool.UserControls.AvalonRoadControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <Style x:Key="TierBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="IconBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="MinWidth" Value="22"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Bar -->
        <Grid Grid.Row="0" Margin="10,8,10,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Sol: Başlık + Toplam -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="AVALON ROADS" FontSize="18" FontWeight="Bold"
                           Foreground="#FFFBB76F" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Border Background="#FF2A2A2A" CornerRadius="4" Padding="10,4" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Toplam: " Foreground="#999" FontSize="12"/>
                        <TextBlock x:Name="ToplamText" Text="316" Foreground="#FFFBB76F" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text=" Harita" Foreground="#999" FontSize="12"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Orta: Arama -->
            <Border Grid.Column="1" Margin="16,0" Background="#FF1A1A1A"
                    BorderBrush="#FF333333" BorderThickness="0,0,0,2" CornerRadius="4">
                <Border BorderBrush="#FFFBB76F" BorderThickness="3,0,0,0" CornerRadius="4">
                    <TextBox x:Name="AramaKutusu" Height="34"
                             Background="Transparent" Foreground="White" FontSize="13"
                             BorderThickness="0" Padding="10,6"
                             TextChanged="Arama_Changed"
                             VerticalContentAlignment="Center">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Resources>
                                    <VisualBrush x:Key="WatermarkBrush" AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                        <VisualBrush.Visual>
                                            <TextBlock Text="  Harita ara..." Foreground="#666" FontSize="13" Margin="8,0,0,0"/>
                                        </VisualBrush.Visual>
                                    </VisualBrush>
                                </Style.Resources>
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background" Value="{StaticResource WatermarkBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Border>
            </Border>

            <!-- Sağ: Sıralama -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <RadioButton x:Name="SortName" Content="Ada Göre" Foreground="#DDD" FontSize="12"
                             IsChecked="True" Checked="Sort_Changed" Margin="0,0,12,0"
                             GroupName="SortGroup"/>
                <RadioButton x:Name="SortTier" Content="Tier'a Göre" Foreground="#DDD" FontSize="12"
                             Checked="Sort_Changed" GroupName="SortGroup"/>
            </StackPanel>
        </Grid>

        <!-- Tier Filter -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="12,2,12,6">
            <TextBlock Text="Filtre:" Foreground="#888" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <CheckBox x:Name="FilterT4" Content="T4" Foreground="#DDD" FontSize="11"
                      IsChecked="True" Checked="Filter_Changed" Unchecked="Filter_Changed" Margin="0,0,10,0"/>
            <CheckBox x:Name="FilterT6" Content="T6" Foreground="#DDD" FontSize="11"
                      IsChecked="True" Checked="Filter_Changed" Unchecked="Filter_Changed" Margin="0,0,10,0"/>
            <CheckBox x:Name="FilterT8" Content="T8" Foreground="#DDD" FontSize="11"
                      IsChecked="True" Checked="Filter_Changed" Unchecked="Filter_Changed" Margin="0,0,10,0"/>
            <CheckBox x:Name="FilterGold" Content="Sadece Gold" Foreground="#FFFBB76F" FontSize="11"
                      Checked="Filter_Changed" Unchecked="Filter_Changed" Margin="10,0,0,0"/>
            <TextBlock x:Name="FiltreliSayiText" Foreground="#888" FontSize="11"
                       VerticalAlignment="Center" Margin="16,0,0,0"/>
        </StackPanel>

        <!-- Map Cards Grid -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="6,0,6,0">
            <WrapPanel x:Name="MapCardsPanel" Margin="4"/>
        </ScrollViewer>

        <!-- Büyük Resim Önizleme -->
        <Grid x:Name="BuyukResimPanel" Grid.Row="0" Grid.RowSpan="3"
              Background="#DD000000" Visibility="Collapsed"
              MouseLeftButtonDown="BuyukResimKapat_Click" Cursor="Hand">
            <Border Background="#FF1A1A1A" BorderBrush="#FF444444" BorderThickness="2"
                    CornerRadius="8" Padding="16"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    MaxWidth="900" MaxHeight="700">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock x:Name="BuyukResimBaslik" FontSize="16" FontWeight="Bold"
                                   Foreground="White" Margin="0,0,10,0"/>
                        <Border x:Name="BuyukResimTierBorder" CornerRadius="4" Padding="8,3" VerticalAlignment="Center">
                            <TextBlock x:Name="BuyukResimTierText" Foreground="White" FontSize="12" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                    <Image x:Name="BuyukResimImage" Stretch="Uniform" MaxHeight="550" MaxWidth="800"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="Kapatmak için tıklayın" Foreground="#666" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
